# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
bin/
include/
lib/
lib64/
share/
*.egg-info/
.coverage
.tox/
.mypy_cache/

# Django
*.log
*.sqlite3
db.sqlite3
/media/  # User-uploaded/generated media files (like audio stories)
/static/ # Compiled static files if you're collecting them, though you might keep source static files
*.pot

# Deep Learning specific
/data/ # Raw and processed data, as it's large and generated by scripts
*.pt # PyTorch model weights (e.g., model.pt, checkpoint.pt)
*.pth
*.safetensors # Hugging Face preferred model format
*.ckpt # Checkpoint files
*.jsonl # If you process data into JSONL and it gets large/is generated

# Editor/OS specific files
.DS_Store # macOS
.vscode/ # VS Code workspace settings (optional, you might want to share some)
.idea/ # PyCharm/IntelliJ IDEA
*~ # Emacs/Vim temporary files
*.swp # Vim swap files
Thumbs.db # Windows thumbnail cache
desktop.ini # Windows custom folder settings