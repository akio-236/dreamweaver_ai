# Deep Learning Specific
# Model checkpoints and saved models
/models/
/checkpoints/
*.pt # PyTorch model files
*.pth # PyTorch model files
*.h5 # Keras/TensorFlow HDF5 models
*.ckpt # TensorFlow checkpoints
runs/ # Often used by TensorBoard/PyTorch Lightning for logging

# Datasets (raw and processed)
# The data directory itself, or specific large files within it
/data/ # Ignore the entire data directory. You should manage datasets separately (e.g., cloud storage, DVC)
# If you want to keep data/ but ignore large files:
# data/*.zip
# data/*.tar.gz
# data/*.bin
# data/*.parquet
# data/*.csv # Be careful with this; small CSVs might be useful in Git

# Logs
*.log
logs/

# Environment variables / configuration files
.env
.flaskenv
config.ini
secrets.py # Or any file holding sensitive API keys, database credentials, etc.

